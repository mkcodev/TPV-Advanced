{
  "name": "next-tpv",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "pnpm --filter @tpv/db db:generate",
    "db:migrate": "pnpm --filter @tpv/db db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
